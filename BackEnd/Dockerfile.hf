FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies, Postgres 17, and compiler tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gnupg \
    lsb-release \
    ca-certificates \
    tesseract-ocr \
    build-essential \
    libpq-dev \
    gcc \
    && echo "deb http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - \
    && apt-get update && apt-get install -y postgresql-17 postgresql-17-pgvector \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama engine binary
RUN curl -fsSL https://ollama.com/install.sh | sh

# Pre-initialize internal Postgres database structure
ENV PGDATA=/var/lib/postgresql/data
RUN mkdir -p "$PGDATA" && chown -R postgres:postgres "$PGDATA" \
    && su - postgres -c "/usr/lib/postgresql/17/bin/initdb -D $PGDATA" \
    && echo "host all all 127.0.0.1/32 trust" >> "$PGDATA/pg_hba.conf" \
    && su - postgres -c "/usr/lib/postgresql/17/bin/pg_ctl -D $PGDATA start" \
    && su - postgres -c "psql -d template1 -c 'CREATE DATABASE ai_study_platform;'" \
    && su - postgres -c "/usr/lib/postgresql/17/bin/pg_ctl -D $PGDATA stop"

WORKDIR /workspace

COPY requirements.txt .
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy your backend files and your exact start.sh script
COPY . .
RUN chmod +x start.sh

# Target the mandatory Hugging Face traffic port
EXPOSE 7860

CMD ["./start.sh"]